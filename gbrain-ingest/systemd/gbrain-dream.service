# systemd USER unit (install: ~/.config/systemd/user/, systemctl --user)
# Nightly gbrain consolidation pass. Shares the ingest flock so it never
# overlaps an ingestion run's LLM usage.
[Unit]
Description=gbrain dream: nightly memory consolidation
After=network-online.target

[Service]
Type=oneshot
EnvironmentFile=%h/.hermes/.env
ExecStart=/usr/bin/flock -w 1800 /tmp/gbrain-ingest.lock %h/.local/bin/gbrain dream
Nice=10
TimeoutStartSec=120min

[Install]
WantedBy=default.target
