# provision.env — config for /agentbox-flash provision-jetson.sh
# Copy to provision.env and fill in. provision.env is gitignored (holds a token).

# --- Jetson Linux BSP (host-side, used for flashing) -----------------------
# Path to an EXTRACTED Linux_for_Tegra/ with apply_binaries.sh already run.
# Get it from developer.nvidia.com/embedded/jetson-linux (public, no login):
#   tar xf Jetson_Linux_R36.x_aarch64.tbz2
#   sudo tar xpf Tegra_Linux_Sample-Root-Filesystem_R36.x_aarch64.tbz2 -C Linux_for_Tegra/rootfs/
#   cd Linux_for_Tegra && sudo ./apply_binaries.sh
BSP_DIR=/home/bob/jetson/Linux_for_Tegra
L4T_VERSION=36.4.0                       # pin so reruns are reproducible

# --- Board + target storage ------------------------------------------------
# Orin Nano Super 8GB devkit on JetPack 6.1+: jetson-orin-nano-devkit-super
# Older JetPack:                                jetson-orin-nano-devkit
BOARD_CONFIG=jetson-orin-nano-devkit-super
# NVMe strongly preferred (installer needs >=16G free). Use "internal" for eMMC/SD.
TARGET_DEVICE=nvme0n1p1

# --- Headless first-boot account (baked into the image) --------------------
BOX_USER=agentbox
BOX_PASS=changeme-strong-pass            # baked into rootfs; rotate after provisioning
BOX_HOST=agentbox
BOX_IP=192.168.55.1                      # Jetson USB device-mode address (default)

# --- AgentBOX source (GitHub is the source of truth) -----------------------
DEPLOY_SOURCE=git                        # git | local
AGENTBOX_GIT_URL=https://github.com/UMB-Advisors/AgentBOX.git
# Until the installer PR merges to main, point at the installer branch:
AGENTBOX_GIT_REF=feat/agentbox-installer
GIT_TOKEN=                               # set if the repo is private (PAT); never logged
# Offline/dev only (DEPLOY_SOURCE=local): rsync this local checkout instead of cloning.
AGENTBOX_REPO=

# --- AgentBOX install ------------------------------------------------------
# "--prototype" = throwaway secrets, gate bypass, no Caddy (bench).
# ""             = production: 1Password (op signin first) + live gate ON.
INSTALL_MODE=--prototype
# REQUIRED — installer dies without it (dashboard image builds against GHCR).
GITHUB_PACKAGES_TOKEN=ghp_replace_me
