; Required for installing @umb-advisors/* private packages from GitHub Packages.
; The auth token is env-resolved by npm at install time — never baked into the
; repo. Set GITHUB_PACKAGES_TOKEN in your shell (local dev) or in .env (Docker
; compose build). The token needs the read:packages scope.
;
; Local workstation:
;   gh auth refresh -s read:packages       # one-time, adds scope to gh token
;   export GITHUB_PACKAGES_TOKEN=$(gh auth token)
;
; M1 / appliance (set in ~/mailbox/.env):
;   GITHUB_PACKAGES_TOKEN=<pat-with-read:packages>
;
; CI (.github/workflows/ci.yml): the install step sets GITHUB_PACKAGES_TOKEN
;   from the repo secret GH_PACKAGES_TOKEN (MBOX-337 — the secret can't be named
;   GITHUB_PACKAGES_TOKEN; the GITHUB_ prefix is reserved). Do NOT use the
;   built-in GITHUB_TOKEN here — @umb-advisors/llm is published from thumbox-platform,
;   which has not granted UMB-Advisors/mailbox Actions access, so GITHUB_TOKEN
;   yields 403 permission_denied:read_package. The secret must be a classic PAT
;   (read:packages scope) belonging to an account that can read the package.

@umb-advisors:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_PACKAGES_TOKEN}
