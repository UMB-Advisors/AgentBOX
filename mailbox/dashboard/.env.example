# MailBOX Zero — dashboard service env template
# Used by the Next.js dashboard container. The root .env.example covers
# the appliance-level secrets; this file covers the dashboard-only
# settings.

# ── Postgres connection ────────────────────────────────────────────────
# Production (containerized on appliance, internal docker network):
POSTGRES_URL=postgresql://mailbox:mailbox@postgres:5432/mailbox
# Dev against the appliance over LAN (replace mailbox/mailbox with real creds):
# POSTGRES_URL=postgresql://mailbox:<password>@192.168.1.45:5432/mailbox
# Dev via SSH tunnel: ssh -L 5432:localhost:5432 bob@192.168.1.45
# POSTGRES_URL=postgresql://mailbox:<password>@localhost:5432/mailbox

# ── n8n webhook URL for triggering MailBOX-Send workflow ───────────────
# Production (containerized on appliance, internal network):
N8N_WEBHOOK_URL=http://n8n:5678/webhook/mailbox-send
# Dev against the appliance over LAN:
# N8N_WEBHOOK_URL=http://192.168.1.45:5678/webhook/mailbox-send

# ── n8n webhook URL for MailBOX-Imap-Send (MBOX-357 P1 T5) ─────────────
# IMAP-provider accounts route their approve/retry sends here; Gmail accounts
# keep using N8N_WEBHOOK_URL above. Only consumed when an IMAP account exists.
N8N_IMAP_WEBHOOK_URL=http://n8n:5678/webhook/mailbox-imap-send

# ── App configuration ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Drafting endpoints (02-07) ─────────────────────────────────────────
# Local Ollama URL — resolved automatically inside the docker network.
# Override only if running the dashboard outside the compose stack.
# OLLAMA_BASE_URL=http://ollama:11434

# ── Local inference runtime (STAQPRO-338 / DR-25) ──────────────────────
# Selects the local inference backend for the classify and local-draft
# paths. Cloud routes are unaffected.
#   ollama    (default) — direct hit to OLLAMA_BASE_URL, no proxy
#   llama-cpp           — route through the dashboard's /api/internal/llm
#                         proxy, which translates Ollama wire shapes to
#                         llama.cpp's /completion + /v1/chat/completions
# Flip is reversible — change this and `docker compose up -d mailbox-dashboard`.
# LOCAL_INFERENCE_RUNTIME=ollama

# Used only when LOCAL_INFERENCE_RUNTIME=llama-cpp. Service runs as the
# `llama-cpp` compose service per the runbook.
# LLAMA_CPP_BASE_URL=http://llama-cpp:8080
# LLAMA_CPP_MODEL=qwen3-4b-ctx4k

# In-cluster URL the local-draft route returns to n8n when the runtime
# is llama-cpp. n8n composes `${baseUrl}/api/chat` against this. Override
# only if the dashboard runs outside the compose stack.
# DASHBOARD_LLM_PROXY_BASE_URL=http://mailbox-dashboard:3001/api/internal/llm

# Cloud-escalation drafting via Ollama Cloud (same /api/chat schema).
# Used when the classifier routes a draft to "cloud" (escalate or
# low-confidence). Empty key = cloud path will fail and the dashboard
# returns the LLM error to n8n. Get a key at https://ollama.com/cloud.
OLLAMA_CLOUD_API_KEY=
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# OLLAMA_CLOUD_MODEL=gpt-oss:120b

# Onboarding live-gate (02-08 wizard not yet built). When set to '1',
# the live-gate route returns {live:true} regardless of the
# mailbox.onboarding row's stage. Useful for dogfood testing before
# the wizard ships. Leave empty in production.
# MAILBOX_LIVE_GATE_BYPASS=1

# ── Onboarding route shared-secret gate (fix/onboarding-route-auth) ──────
# When set, POST requests to /api/internal/onboarding/* must include the
# header `x-onboarding-token: <value>` or they receive 401. Leave UNSET on
# any box whose wizard client components have not been updated to send the
# header (all current installs) — the operative protection is Caddy basic_auth.
# Generate: openssl rand -hex 32
# ONBOARDING_API_TOKEN=

# ── RAG retrieval (M3.5 / STAQPRO-191) ─────────────────────────────────
# Qdrant vector DB URL. Resolved automatically inside the docker network.
# Override only if running the dashboard outside the compose stack.
# QDRANT_URL=http://qdrant:6333

# Privacy gate for cloud-route retrieval. PRIVACY-FIRST DEFAULT (unset).
# Local route always retrieves; cloud route retrieves ONLY when this is
# '1'. Setting it ships per-call retrieved excerpts to Ollama Cloud /
# Anthropic — opt in deliberately. Per the Constraints "no bulk corpus
# sent to cloud" only relaxes for per-call augmentation.
# RAG_CLOUD_ROUTE_ENABLED=1

# Retrieval tunables. Defaults are conservative for the Qwen3 4096-token
# context: 3 snippets × 600 chars ≈ 450 tokens of retrieved context, well
# under headroom (real headroom is ~1000 tokens after system + user
# prompt). Increase top_k for higher recall when the corpus is rich;
# trim excerpt_chars first if you see truncation in cloud-route prompts.
# RAG_RETRIEVE_TOP_K=3
# RAG_RETRIEVE_EXCERPT_CHARS=600

# Backfill lookback window for `npm run rag:backfill` (one-shot Qdrant
# seed from mailbox.inbox_messages + mailbox.sent_history). Idempotent
# on point UUID — re-run safely after schema changes. Default 90 days.
# RAG_BACKFILL_LOOKBACK_DAYS=90

# ── Google OAuth — Calendar + Tasks (MBOX-130 / MBOX-129) ───────────────
# Shared Google OAuth client + AES-256-GCM token storage backing the
# calendar pre-read (read-only) and the Google Tasks handoff (read/write).
# One mailbox.oauth_tokens row per provider; refresh tokens encrypted at
# rest. The connect flow lives at /dashboard/settings/integrations.

# REQUIRED — 32-byte (64 hex char) key that encrypts stored refresh tokens
# (AES-256-GCM, lib/oauth/google.ts). Generate: `openssl rand -hex 32`.
# Distinct from MAILBOX_OAUTH_STATE_SECRET (key separation — a leak of one
# must not compromise the other). The OAuth providers will not connect /
# fetch without this set.
MAILBOX_OAUTH_TOKEN_KEY=

# REQUIRED — secret used to HMAC-sign the OAuth connect-flow `state` param
# so the callback can verify the round-trip originated from this appliance.
# Generate: `openssl rand -hex 32`. Must differ from MAILBOX_OAUTH_TOKEN_KEY.
MAILBOX_OAUTH_STATE_SECRET=

# REQUIRED — Google Cloud OAuth client credentials (Web application client).
# Register the redirect URI `${MAILBOX_PUBLIC_BASE_URL}${basePath}/api/oauth/
# google/callback` in the Google Cloud console for this client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# REQUIRED — the appliance's public https origin (no trailing path), used to
# build the OAuth callback redirect URI and the task backlink. Example:
# MAILBOX_PUBLIC_BASE_URL=https://mailbox.heronlabsinc.com
MAILBOX_PUBLIC_BASE_URL=

# ── Calendar pre-read (MBOX-130) ────────────────────────────────────────
# Read-only Google Calendar pre-read at draft time for `scheduling` mail, so
# the drafter can propose concrete open slots instead of "let me check."

# OPTIONAL — master feature flag. '1' enables the pre-read; anything else (or
# unset) disables it entirely (reason=disabled, no DB / no fetch). Default off.
# CALENDAR_CONTEXT_ENABLED=1

# OPTIONAL — privacy gate for the CLOUD draft route. PRIVACY-FIRST DEFAULT
# (unset). Local route always reads the calendar; the cloud route reads it
# ONLY when this is '1' (otherwise reason=cloud_gated, no calendar data leaves
# the appliance). Mirrors RAG_CLOUD_ROUTE_ENABLED. Default off.
# CALENDAR_CLOUD_ROUTE_ENABLED=1

# OPTIONAL — how many days ahead the availability window looks. Positive
# integer; bad/missing value falls back to 14.
# CALENDAR_LOOKAHEAD_DAYS=14

# OPTIONAL — per-draft fetch cache TTL in ms (keyed by draft_source so local
# and cloud never share a cache entry across the privacy gate). Bad/missing
# value falls back to 30000 (30s).
# CALENDAR_CACHE_TTL_MS=30000

# ── Google Tasks handoff (MBOX-129) ─────────────────────────────────────
# Push extracted action items to Google Tasks (read/write `tasks` scope).

# OPTIONAL — which task provider the push handoff targets. 'google_tasks' is
# the only provider wired in v1 ('linear' is reserved for v2). Defaults to the
# code default (google_tasks); set only to be explicit.
# TASK_PROVIDER=google_tasks

# OPTIONAL — which Google Tasks list new tasks land in. Defaults to the
# operator's primary list ('@default'). Set to a specific tasklist id to route
# MailBOX tasks into a dedicated list.
# GOOGLE_TASKS_LIST_ID=@default

# ── Appliance-level vars the integrations read ──────────────────────────
# These are normally provisioned at the appliance/compose level, but the
# Calendar + OAuth + Tasks modules read them directly — set them if running
# the dashboard outside the full compose stack.

# Operator's timezone (IANA, e.g. America/Los_Angeles). The calendar pre-read
# renders event times in THIS zone — the mailbox-dashboard container sets no
# TZ and would otherwise default to UTC, showing wrong availability. Falls
# back to 'UTC' when unset. Same var n8n uses for the digest schedule.
# GENERIC_TIMEZONE=America/Los_Angeles

# The dashboard is served under a basePath (/dashboard). Used to build the
# OAuth callback redirect URI and the task backlink. Defaults to '' (empty).
# NEXT_PUBLIC_BASE_PATH=/dashboard
