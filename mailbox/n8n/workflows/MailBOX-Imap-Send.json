      "id": "d2c00000-0000-0000-0000-000000000005",
      "name": "Acquire Send Lock",
      "parameters": {
        "operation": "executeQuery",
        "options": {},
        "query": "-- Migration 025 idempotency lock (provider-neutral). CAS-acquire BEFORE the\n-- SMTP send: set send_attempt_at = NOW() iff currently NULL. 0 rows returned =\n-- a prior attempt is in flight or crashed mid-send \u2192 refuse to re-fire. Operator\n-- verifies in the Sent folder + clears send_attempt_at before another retry.\nUPDATE mailbox.drafts\nSET send_attempt_at = NOW(),\n    updated_at      = NOW()\nWHERE id = {{ Number($('Load Draft IMAP').item.json.draft_id) }}\n  AND status IN ('approved', 'edited')\n  AND send_attempt_at IS NULL\nRETURNING id;"
      },
      "position": [
        1056,
        320
      ],
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5
    },
