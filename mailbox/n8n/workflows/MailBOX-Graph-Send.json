      "parameters": {
        "operation": "executeQuery",
        "options": {},
        "query": "-- Migration 025 idempotency lock (provider-neutral). CAS-acquire BEFORE the\n-- Graph send: set send_attempt_at = NOW() iff currently NULL. 0 rows returned =\n-- a prior attempt is in flight or crashed mid-send -> refuse to re-fire.\nUPDATE mailbox.drafts\nSET send_attempt_at = NOW(),\n    updated_at      = NOW()\nWHERE id = {{ Number($('Load Draft Graph').item.json.draft_id) }}\n  AND status IN ('approved', 'edited')\n  AND send_attempt_at IS NULL\nRETURNING id;"
      },
      "credentials": {
        "postgres": {
