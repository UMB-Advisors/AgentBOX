        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": {\n    \"subject\": {{ JSON.stringify(($('Load Draft Graph').item.json.original_subject || '').toLowerCase().startsWith('re:') ? $('Load Draft Graph').item.json.original_subject : 'Re: ' + ($('Load Draft Graph').item.json.original_subject || '')) }},\n    \"body\": { \"contentType\": \"Text\", \"content\": {{ JSON.stringify($('Load Draft Graph').item.json.draft_body || '') }} },\n    \"toRecipients\": [ { \"emailAddress\": { \"address\": {{ JSON.stringify($('Load Draft Graph').item.json.from_addr || '') }} } } ]\n  },\n  \"saveToSentItems\": true\n}",
        "options": {
