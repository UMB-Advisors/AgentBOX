# AgentBOX compose override — adds the Funnel-fronting basic_auth Caddy and puts
# n8n behind it for the Gmail-OAuth callback. Copy to docker-compose.override.yml
# in the MailBOX repo root, replace REPLACE_WITH_TAILNET_FQDN, then:
#   docker compose up -d caddy-funnel n8n
#   tailscale funnel --bg 8088
services:
  caddy-funnel:
    image: caddy:2
    ports:
      - "127.0.0.1:8088:8088"   # localhost only; Funnel reaches it
    volumes:
      - ./caddy/Caddyfile.funnel:/etc/caddy/Caddyfile:ro
    restart: unless-stopped
  n8n:
    environment:
      # n8n runs HTTP internally; Funnel terminates TLS and advertises https.
      N8N_PROTOCOL: http
      N8N_SECURE_COOKIE: "false"
      N8N_EDITOR_BASE_URL: https://REPLACE_WITH_TAILNET_FQDN/
      WEBHOOK_URL: https://REPLACE_WITH_TAILNET_FQDN/
      N8N_HOST: REPLACE_WITH_TAILNET_FQDN
